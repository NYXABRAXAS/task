# ============================================================
#  ProHorizon Scope Tracker — Environment Variables
#  Copy to .env for local development.
#  On Render: set these in the Dashboard → Environment tab.
#  render.yaml auto-configures most variables.
# ============================================================

# ── Application ─────────────────────────────────────────────
NODE_ENV=development
PORT=5000

# ── PostgreSQL ───────────────────────────────────────────────
# Option A: Single connection string (used by Render)
DATABASE_URL=postgresql://postgres:Admin%40123@localhost:5432/prohorizon_db

# Option B: Individual params (used for local dev without DATABASE_URL)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=ScopeTracker
DB_USER=postgres
DB_PASSWORD=Admin@123
DB_SSL=false
DB_POOL_MAX=10
DB_POOL_MIN=2
DB_POOL_ACQUIRE=30000
DB_POOL_IDLE=10000

# ── Security ─────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=generate_64_byte_hex_here
JWT_EXPIRES_IN=8h
JWT_REFRESH_SECRET=34ebc510297d676ce30b347d3dd658c318a3c499f9b2a4f93f202eb2fb6b06b8b54edba8d66b453bd9309470130565a1743ff15ba1acda44508726f1b1e9c5a7
JWT_REFRESH_EXPIRES_IN=7d
BCRYPT_ROUNDS=12

# ── File Upload ──────────────────────────────────────────────
UPLOAD_MAX_SIZE=10485760
UPLOAD_PATH=./uploads
ALLOWED_FILE_TYPES=pdf,doc,docx,xls,xlsx,png,jpg,jpeg,txt,csv

# ── Email (optional — for notifications) ─────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your@email.com
SMTP_PASS=your_app_password
EMAIL_FROM_NAME=ProHorizon Scope Tracker
EMAIL_FROM_ADDRESS=noreply@yourdomain.com

# ── Rate Limiting ────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=500
AUTH_RATE_LIMIT_MAX=10

# ── Account Lock ─────────────────────────────────────────────
MAX_FAILED_LOGIN_ATTEMPTS=5
ACCOUNT_LOCK_DURATION_MINUTES=30

# ── Logging ──────────────────────────────────────────────────
LOG_LEVEL=warn
LOG_PATH=./logs

# ── Features ─────────────────────────────────────────────────
SWAGGER_ENABLED=false
AUTO_SEED=true
