# ================================================================
#  ProHorizon Scope Tracker — Environment Variables
#  Copy to .env for local development.
#  On Render: set these in Dashboard → Environment.
# ================================================================

# ── Node ──────────────────────────────────────────────────────────
NODE_ENV=development
PORT=5000

# ── Database (Option 1 — Render / cloud / connection string) ──────
# Render sets this automatically when using Blueprint deployment.
# For ElephantSQL / Railway / Neon / Supabase — paste the URL here.
DATABASE_URL=

# ── Database (Option 2 — individual params, local dev) ────────────
# Used when DATABASE_URL is NOT set. SSL is auto-enabled in production.
DB_HOST=localhost
DB_PORT=5432
DB_NAME=prohorizon_db
DB_USER=postgres
DB_PASSWORD=yourpassword
DB_SSL=false

# ── JWT ───────────────────────────────────────────────────────────
JWT_SECRET=change-this-to-a-long-random-string-in-production
JWT_REFRESH_SECRET=change-this-refresh-secret-too
JWT_EXPIRES_IN=8h
JWT_REFRESH_EXPIRES_IN=7d
BCRYPT_ROUNDS=12

# ── Rate limiting ────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=500
AUTH_RATE_LIMIT_MAX=10

# ── Account security ──────────────────────────────────────────────
MAX_FAILED_LOGIN_ATTEMPTS=5
ACCOUNT_LOCK_DURATION_MINUTES=30

# ── File uploads ──────────────────────────────────────────────────
UPLOAD_MAX_SIZE=10485760
UPLOAD_PATH=./uploads
ALLOWED_FILE_TYPES=pdf,doc,docx,xls,xlsx,png,jpg,jpeg,txt,csv

# ── Logging ───────────────────────────────────────────────────────
LOG_LEVEL=debug
LOG_PATH=./logs

# ── Features ──────────────────────────────────────────────────────
SWAGGER_ENABLED=true
AUTO_SEED=true

# ── Email (optional) ──────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
EMAIL_FROM_NAME=ProHorizon Scope Tracker
EMAIL_FROM_ADDRESS=noreply@prohorizon.com
